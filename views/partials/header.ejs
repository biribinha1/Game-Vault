<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <meta charset="UTF-8">
    <title>Game Vault</title>
    <style>
        nav { background-color: #333; color: white; padding: 15px; }
        nav a { color: white; margin-right: 15px; text-decoration: none; }

        body {
            font-family: 'Poppins', sans-serif;
        }

        .list-group-item img {
            width: 100%;
            height: 30%;
            object-fit: cover;
            border-radius: 15px;
            margin: 10px auto;
            
        }

        .nota {
            font-weight: bold;
            color: #f59e0b;
        }

        .list-group-item h3 {
            height: 80px;
            overflow: hidden;
        }

        .list-group-item form{
            margin-top: 10px;
            width: auto;
            min-width: 250px;
            border-radius: 15px;
        }

        .list-group-item{
            border-radius: 15px !important;
            height: 400px;
            width: 250px;
            min-height: 320px;
            padding: 15px;
            display: flex;
            flex-direction: column;
            background-color:whitesmoke;
            border: none;
            
        }

        .card {
            background-color:#333;
            color: white;
            border-radius: 10px;
        }

        li button {
            margin-top: 10px;  
        }
        
        .list-group {
            list-style: none;
            padding-left: 0;
            padding: 20px;
            flex-wrap: wrap;
            display: flex;
            flex-direction: row;
            gap: 67px;
            
        }

        .mb-3{
            display: flex;
            flex-direction: column;
        }

        li > div {
            display: flex;
            flex-direction: row;
            align-items: center;
            
        }

        div > h6 {
            margin-top: 15px;
            padding-left: 110px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="btn btn-outline-light" href="/">Página Inicial</a>
            <a class="btn btn-success" href="/cadastrar">Adicionar Jogo</a>
        
        </div>
    </nav>
    
    <div class="container" style="padding: 20px;">